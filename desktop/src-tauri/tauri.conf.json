{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Toolkit",
  "version": "0.1.0",
  "identifier": "com.ostris.aitoolkit.desktop",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "AI Toolkit",
        "width": 960,
        "height": 720,
        "minWidth": 720,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Friendly launcher for ai-toolkit training jobs",
    "longDescription": "A simple desktop app that makes it easy to start, stop, and watch ai-toolkit training jobs without using the terminal."
  }
}
